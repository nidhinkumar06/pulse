# ── Google AI ───────────────────────────────────────────────
GOOGLE_GENAI_API_KEY=your_google_api_key_here

# ── NeonDB (Prisma) ─────────────────────────────────────────
# Get both URLs from: https://console.neon.tech → your project → Connection Details

# Pooled connection — used by the app at runtime (via pgBouncer)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15

# Direct connection — used ONLY by `prisma migrate` (bypasses pooler)
DIRECT_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
